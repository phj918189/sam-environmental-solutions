# ===== 사이트 URL (웹 주소) =====
# 커스텀 도메인 사용 시 아래 값을 변경하세요.
# 변경 후 npm run replace-site-url 실행 (또는 npm run build 시 자동 실행)
VITE_SITE_URL=https://samyangenv.com

# ===== AI 챗봇 (나중에 활성화 시, docs/AI_SETUP.md 참고) =====
# true로 설정 시 우측 하단 챗봇 버튼 표시. 비워두면 비활성화.
# VITE_ENABLE_AI_CHAT=

# https://platform.openai.com/api-keys 에서 발급 (generate-rag, API용)
# OPENAI_API_KEY=sk-xxx

# 배포 시 API가 다른 도메인에 있으면 절대 경로 지정
# VITE_AI_API_URL=

# ===== 문의 폼 (Web3Forms) =====
# https://web3forms.com 에서 무료 Access Key 발급
# 대시보드에서 수신 이메일 주소 설정
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key
